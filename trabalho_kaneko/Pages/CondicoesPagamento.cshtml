@page
@model trabalho_kaneko.Pages.CondicoesPagamentoModel
@{
    ViewData["Title"] = "Nova Condição de Pagamento";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/CondicoesPagamentoListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm border-success">
        <div class="card-header bg-success text-white fw-bold">
            <h4 class="mb-0">+ Nova Condição de Pagamento</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-3 align-items-center">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Descrição da Condição</label>
                        <input asp-for="CondicaoObj.CondicaoPagamento" class="form-control" required maxlength="50" placeholder="Ex: 15/30 Dias, À Vista..." />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-primary">Quantidade de Parcelas</label>
                        <input asp-for="CondicaoObj.QuantidadeParcelas" type="number" class="form-control" required min="1" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-danger">Juros (%)</label>
                        <input asp-for="CondicaoObj.Juros" type="number" step="0.01" class="form-control" placeholder="0,00" />
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4 fw-bold">Salvar Condição</button>
                </div>
            </form>
        </div>
    </div>
</div>