@page
@model trabalho_kaneko.Pages.CondicoesPagamentoEditarModel
@{
    ViewData["Title"] = "Editar Condição de Pagamento";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/CondicoesPagamentoListar" class="btn btn-secondary btn-sm">⬅ Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark fw-bold">
            <h4 class="mb-0">✏️ Editar Condição</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="CondicaoObj.IdCondicao" />
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-3 align-items-center">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Descrição da Condição</label>
                        <input asp-for="CondicaoObj.CondicaoPagamento" class="form-control" required maxlength="50" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-primary">Qtd. de Parcelas</label>
                        <input asp-for="CondicaoObj.QuantidadeParcelas" type="number" class="form-control" required min="1" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-danger">Juros (%)</label>
                        <input asp-for="CondicaoObj.Juros" type="number" step="0.01" class="form-control" />
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>