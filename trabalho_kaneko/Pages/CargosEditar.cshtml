@page
@model trabalho_kaneko.Pages.CargosEditarModel
@{
    ViewData["Title"] = "Editar Cargo";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/CargosListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark fw-bold">
            <h4 class="mb-0">✏️ Editar Cargo</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="CargoObj.IdCargo" />
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Nome do Cargo</label>
                        <input asp-for="CargoObj.Cargo" class="form-control" required maxlength="50" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Descrição (Opcional)</label>
                        <textarea asp-for="CargoObj.Descricao" class="form-control" rows="3" maxlength="150"></textarea>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>