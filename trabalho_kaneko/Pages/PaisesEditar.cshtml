@page
@model trabalho_kaneko.Pages.PaisesEditarModel
@{
    ViewData["Title"] = "Editar País";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/PaisesListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark fw-bold">
            <h4 class="mb-0">Editar País</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="PaisObj.IdPais" />
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label fw-bold">Nome do País</label>
                        <input asp-for="PaisObj.Pais" class="form-control" required maxlength="60" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold">Sigla</label>
                        <input asp-for="PaisObj.Sigla" class="form-control" required maxlength="3" style="text-transform: uppercase;" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold">DDI</label>
                        <input asp-for="PaisObj.Ddi" class="form-control" required maxlength="10" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Moeda</label>
                        <input asp-for="PaisObj.Moeda" class="form-control" required maxlength="50" />
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>