@page
@model trabalho_kaneko.Pages.GruposModel
@{
    ViewData["Title"] = "Novo Grupo";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/GruposListar" class="btn btn-secondary btn-sm">⬅ Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm border-success">
        <div class="card-header bg-success text-white fw-bold">
            <h4 class="mb-0">+ Novo Grupo</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Nome do Grupo</label>
                        <input asp-for="GrupoObj.Grupo" class="form-control" required maxlength="50" />
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4 fw-bold">Salvar Grupo</button>
                </div>
            </form>
        </div>
    </div>
</div>