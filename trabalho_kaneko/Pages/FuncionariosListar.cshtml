@page
@model trabalho_kaneko.Pages.FuncionariosListarModel
@{
    ViewData["Title"] = "Gestão de Funcionários";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestão de Funcionários</h2>
        <a asp-page="/Funcionarios" class="btn btn-success fw-bold">+ Novo Funcionário</a>
    </div>

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">@TempData["MensagemSucesso"]</div>
    }
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm">@TempData["MensagemErro"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white fw-bold">
            Funcionários Cadastrados
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 70px;">Código</th>
                            <th>Nome</th>
                            <th>CPF</th>
                            <th>Cargo</th>
                            <th>Cidade</th>
                            <th>Telefone</th>
                            <th class="text-center" style="width: 160px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaFuncionarios != null && Model.ListaFuncionarios.Count > 0)
                        {
                            foreach (var item in Model.ListaFuncionarios)
                            {
                                <tr>
                                    <td>@item.IdFuncionario</td>
                                    <td class="fw-bold">@item.Funcionario @(!string.IsNullOrEmpty(item.Apelido) ? $"({item.Apelido})" : "")</td>
                                    <td>@item.Cpf</td>
                                    <td><span class="badge bg-info text-dark fw-bold">@item.NomeCargo</span></td>
                                    <td>@item.NomeCidade</td>
                                    <td>@item.Telefone</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-page="/FuncionariosEditar" asp-route-id="@item.IdFuncionario" class="btn btn-warning btn-sm fw-bold">
                                                Editar
                                            </a>
                                            <form method="post" asp-page-handler="Deletar" asp-route-id="@item.IdFuncionario"
                                                  onsubmit="return confirm('Tem certeza que deseja excluir este funcionário?');"
                                                  class="m-0 p-0">
                                                <button type="submit" class="btn btn-danger btn-sm fw-bold">
                                                    Excluir
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">Nenhum funcionário cadastrado ainda.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>