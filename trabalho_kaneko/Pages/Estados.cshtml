@page
@model trabalho_kaneko.Pages.EstadosModel
@{
    ViewData["Title"] = "Cadastro de Estados";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/EstadosListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Novo Estado</h4>
        </div>
        <div class="card-body">

            @if (TempData["MensagemSucesso"] != null)
            {
                <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nome do Estado</label>
                        <input asp-for="Estado.Estado" class="form-control" placeholder="Ex: Paraná" required maxlength="50" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold">UF</label>
                        <input asp-for="Estado.Uf" class="form-control" placeholder="Ex: PR" required maxlength="2" style="text-transform: uppercase;" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">País</label>
                        <select asp-for="Estado.IdPais" class="form-select" required>
                            <option value="">-- Selecione um País --</option>
                            @if (Model.ListaPaisesDisponiveis != null)
                            {
                                foreach (var pais in Model.ListaPaisesDisponiveis)
                                {
                                    <option value="@pais.IdPais">@pais.Pais</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4">Salvar Estado</button>
                </div>
            </form>
        </div>
    </div>
</div>