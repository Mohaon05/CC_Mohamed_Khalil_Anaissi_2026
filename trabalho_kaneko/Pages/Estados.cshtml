@page
@model trabalho_kaneko.Pages.EstadosModel
@{
    ViewData["Title"] = "Cadastro de Estados";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Novo Estado</h4>
        </div>
        <div class="card-body">

            @if (TempData["MensagemSucesso"] != null)
            {
                <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nome do Estado</label>
                        <input asp-for="Estado.Estado" class="form-control" placeholder="Ex: Paraná" required maxlength="50" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold">UF</label>
                        <input asp-for="Estado.Uf" class="form-control" placeholder="Ex: PR" required maxlength="2" style="text-transform: uppercase;" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">País</label>
                        <select asp-for="Estado.IdPais" class="form-select" required>
                            <option value="">-- Selecione um País --</option>
                            @if (Model.ListaPaisesDisponiveis != null)
                            {
                                foreach (var pais in Model.ListaPaisesDisponiveis)
                                {
                                    <option value="@pais.IdPais">@pais.Pais</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4">Salvar Estado</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container mt-4 mb-5">
    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">Estados Cadastrados</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Estado</th>
                            <th>UF</th>
                            <th>País</th>
                            <th>Data de Inclusão</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaEstados != null && Model.ListaEstados.Count > 0)
                        {
                            foreach (var item in Model.ListaEstados)
                            {
                                <tr>
                                    <td>@item.IdEstado</td>
                                    <td class="fw-bold">@item.Estado</td>
                                    <td>@item.Uf</td>
                                    <td>@item.NomePais</td>
                                    <td>@item.DataInclusao?.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-3">Nenhum estado cadastrado ainda.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>