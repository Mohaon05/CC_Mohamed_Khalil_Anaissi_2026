@page
@model trabalho_kaneko.Pages.EstadosModel
@{
    ViewData["Title"] = "Cadastro de Estados";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/EstadosListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">+ Novo Estado</h4>
        </div>
        <div class="card-body">

            @if (TempData["MensagemSucesso"] != null)
            {
                <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold campo-obrigatorio">Estado</label>
                        <input asp-for="Estado.Estado" class="form-control" placeholder="Ex: Paraná" required maxlength="50" style="text-transform: uppercase;" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold campo-obrigatorio">UF</label>
                        <input asp-for="Estado.Uf" class="form-control" placeholder="Ex: PR" required maxlength="2" style="text-transform: uppercase;" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold campo-obrigatorio">País</label>
                        <div class="input-group">
                            <select asp-for="Estado.IdPais" class="form-select" id="selectPais" required>
                                <option value="">-- Selecione um País --</option>
                                @if (Model.ListaPaisesDisponiveis != null)
                                {
                                    foreach (var pais in Model.ListaPaisesDisponiveis)
                                    {
                                        <option value="@pais.IdPais">@pais.Pais</option>
                                    }
                                }
                            </select>
                            <button class="btn btn-outline-success fw-bold" type="button" data-bs-toggle="modal" data-bs-target="#modalNovoPais">
                                + Novo
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4">Salvar Estado</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNovoPais" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content border-success shadow-lg">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold text-uppercase">Gestão Rápida de Países</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body bg-light">

                <div class="card shadow-sm border-secondary mb-4">
                    <div class="card-header bg-secondary text-white fw-bold text-uppercase">
                        Países Cadastrados
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">
                            <table class="table table-striped table-hover mb-0 text-center" style="font-size: 0.9rem;">
                                <thead style="position: sticky; top: 0; z-index: 1;" class="table-dark">
                                    <tr>
                                        <th>CÓDIGO</th>
                                        <th>PAÍS</th>
                                        <th>SIGLA</th>
                                        <th>DDI</th>
                                        <th>MOEDA</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ListaPaisesDisponiveis != null)
                                    {
                                        foreach (var pais in Model.ListaPaisesDisponiveis)
                                        {
                                            <tr>
                                                <td>@pais.IdPais</td>
                                                <td class="fw-bold">@pais.Pais</td>
                                                <td class="text-uppercase">@pais.Sigla</td>
                                                <td>@pais.Ddi</td>
                                                <td class="text-uppercase">@pais.Moeda</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-success">
                    <div class="card-header bg-success text-white fw-bold text-uppercase">
                        + Novo País
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="form-label fw-bold campo-obrigatorio text-uppercase">País</label>
                                <input type="text" id="modalPaisNome" class="form-control" maxlength="60" placeholder="EX: BRASIL" style="text-transform: uppercase;" required />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-bold campo-obrigatorio text-uppercase">Sigla</label>
                                <input type="text" id="modalPaisSigla" class="form-control" maxlength="3" placeholder="BR" style="text-transform: uppercase;" required />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-bold campo-obrigatorio text-uppercase">DDI</label>
                                <input type="text" id="modalPaisDdi" class="form-control" maxlength="10" placeholder="+55" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold campo-obrigatorio text-uppercase">Moeda</label>
                                <input type="text" id="modalPaisMoeda" class="form-control" maxlength="50" placeholder="REAL (BRL)" style="text-transform: uppercase;" required />
                            </div>
                        </div>
                        <div id="modalPaisErro" class="text-danger fw-bold d-none mt-3">Erro ao salvar país. Verifique os dados.</div>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success fw-bold" onclick="salvarPaisAjax()">Salvar País</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function salvarPaisAjax() {
            // 1. Pega os valores
            const nome = document.getElementById('modalPaisNome').value;
            const sigla = document.getElementById('modalPaisSigla').value;
            const ddi = document.getElementById('modalPaisDdi').value;
            const moeda = document.getElementById('modalPaisMoeda').value;

            if(!nome || !sigla || !ddi || !moeda) {
                alert('Por favor, preencha todos os campos do país!');
                return;
            }

            // 2. Pega o Token de Segurança do ASP.NET
            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenElement) {
                alert('Erro: Token de segurança não encontrado na página.');
                return;
            }

            // 3. Monta os dados no formato de Formulário Seguro
            const formData = new URLSearchParams();
            formData.append('paisNome', nome);
            formData.append('paisSigla', sigla);
            formData.append('paisDdi', ddi);
            formData.append('paisMoeda', moeda);

            // 4. Envia a requisição
            fetch('?handler=CriarPaisRapido', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': tokenElement.value
                },
                body: formData.toString()
            })
            .then(response => {
                if (!response.ok) throw new Error("Erro na comunicação com o servidor.");
                return response.json();
            })
            .then(data => {
                if (data.sucesso) {
                    // Cria a nova opção dinamicamente no Select
                    const select = document.getElementById('selectPais');
                    const option = new Option(data.nome, data.id, true, true);
                    select.add(option);

                    // Fecha o Pop-up na tela
                    const modal = bootstrap.Modal.getInstance(document.getElementById('modalNovoPais'));
                    modal.hide();

                    // Limpa os campos para a próxima vez
                    document.getElementById('modalPaisNome').value = '';
                    document.getElementById('modalPaisSigla').value = '';
                    document.getElementById('modalPaisDdi').value = '';
                    document.getElementById('modalPaisMoeda').value = '';
                    document.getElementById('modalPaisErro').classList.add('d-none');
                } else {
                    document.getElementById('modalPaisErro').classList.remove('d-none');
                }
            })
            .catch(error => {
                console.error('Erro de conexão:', error);
                document.getElementById('modalPaisErro').classList.remove('d-none');
            });
        }
    </script>
}