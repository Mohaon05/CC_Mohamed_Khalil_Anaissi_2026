@page
@model trabalho_kaneko.Pages.FuncionariosModel
@{
    ViewData["Title"] = "Novo Funcionário";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/FuncionariosListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm border-success">
        <div class="card-header bg-success text-white fw-bold">
            <h4 class="mb-0">+ Novo Funcionário</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-3">
                    <h5 class="border-bottom pb-2">Identificação</h5>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nome Completo</label>
                        <input asp-for="Funcionario.Funcionario" class="form-control" required maxlength="50" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Apelido / Nome Social</label>
                        <input asp-for="Funcionario.Apelido" class="form-control" maxlength="50" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">CPF (Apenas números)</label>
                        <input asp-for="Funcionario.Cpf" class="form-control" required maxlength="11" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">RG</label>
                        <input asp-for="Funcionario.Rg" class="form-control" maxlength="10" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Data de Nascimento</label>
                        <input asp-for="Funcionario.DataNascimento" type="date" class="form-control" />
                    </div>

                    <h5 class="mt-4 border-bottom pb-2">Contrato e Atribuição</h5>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Cargo</label>
                        <select asp-for="Funcionario.IdCargo" class="form-select" required>
                            <option value="">-- Selecione o Cargo --</option>
                            @foreach (var cargo in Model.ListaCargos)
                            {
                                <option value="@cargo.IdCargo">@cargo.Cargo</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Salário (R$)</label>
                        <input asp-for="Funcionario.Salario" type="number" step="0.01" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Data de Admissão</label>
                        <input asp-for="Funcionario.DataContratado" type="date" class="form-control" />
                    </div>

                    <h5 class="mt-4 border-bottom pb-2">Contato</h5>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">E-mail</label>
                        <input asp-for="Funcionario.Email" type="email" class="form-control" maxlength="50" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Telefone / Celular</label>
                        <input asp-for="Funcionario.Telefone" class="form-control" maxlength="15" />
                    </div>

                    <h5 class="mt-4 border-bottom pb-2">Endereço</h5>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">CEP</label>
                        <input asp-for="Funcionario.Cep" class="form-control" maxlength="8" />
                    </div>

                    <div class="col-md-7">
                        <label class="form-label fw-bold">Logradouro (Rua, Av.)</label>
                        <input asp-for="Funcionario.Logradouro" class="form-control" maxlength="50" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold">Número</label>
                        <input asp-for="Funcionario.Numero" class="form-control" maxlength="10" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Complemento</label>
                        <input asp-for="Funcionario.Complemento" class="form-control" maxlength="50" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Bairro</label>
                        <input asp-for="Funcionario.Bairro" class="form-control" maxlength="50" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Cidade</label>
                        <select asp-for="Funcionario.IdCidade" class="form-select" required>
                            <option value="">-- Selecione a Cidade --</option>
                            @foreach (var cidade in Model.ListaCidades)
                            {
                                <option value="@cidade.IdCidade">@cidade.Cidade</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4 fw-bold">Salvar Funcionário</button>
                </div>
            </form>
        </div>
    </div>
</div>