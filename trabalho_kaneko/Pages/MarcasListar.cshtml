@page
@model trabalho_kaneko.Pages.MarcasListarModel
@{
    ViewData["Title"] = "Gestão de Marcas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestão de Marcas</h2>
        <a asp-page="/Marcas" class="btn btn-success fw-bold">+ Nova Marca</a>
    </div>

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">@TempData["MensagemSucesso"]</div>
    }
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm">@TempData["MensagemErro"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white fw-bold">
            Marcas Cadastradas
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 100px;">Código</th>
                            <th>Marca</th>
                            <th>Grupo Pertencente</th>
                            <th class="text-center" style="width: 160px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaMarcas != null && Model.ListaMarcas.Count > 0)
                        {
                            foreach (var item in Model.ListaMarcas)
                            {
                                <tr>
                                    <td>@item.IdMarca</td>
                                    <td class="fw-bold">@item.Marca</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.NomeGrupo))
                                        {
                                            <span class="badge bg-info text-dark">@item.NomeGrupo</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Sem Grupo</span>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-page="/MarcasEditar" asp-route-id="@item.IdMarca" class="btn btn-warning btn-sm fw-bold">Editar</a>
                                            <form method="post" asp-page-handler="Deletar" asp-route-id="@item.IdMarca" onsubmit="return confirm('Excluir esta marca?');" class="m-0 p-0">
                                                <button type="submit" class="btn btn-danger btn-sm fw-bold">Excluir</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">Nenhuma marca cadastrada.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>