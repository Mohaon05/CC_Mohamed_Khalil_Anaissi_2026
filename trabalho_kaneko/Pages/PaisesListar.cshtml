@page
@model trabalho_kaneko.Pages.PaisesListarModel
@{
    ViewData["Title"] = "Países Cadastrados";
}

<div class="container mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Gestão de Países</h3>
        <a asp-page="/Paises" class="btn btn-success fw-bold">+ Novo País</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">Países Cadastrados</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>País</th>
                            <th>Sigla</th>
                            <th>Data de Inclusão</th>
                            <th>Última Alteração</th>
                            <th class="text-center" style="width: 120px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaPaises != null && Model.ListaPaises.Count > 0)
                        {
                            foreach (var item in Model.ListaPaises)
                            {
                                <tr>
                                    <td>@item.IdPais</td>
                                    <td class="fw-bold">@item.Pais</td>
                                    <td>@item.Sigla</td>
                                    <td>@item.DataInclusao.ToString("dd/MM/yyyy HH:mm")</td>

                                    <td>@item.DataAlteracao?.ToString("dd/MM/yyyy HH:mm")</td>

                                    <td class="text-center">
                                        <a asp-page="/PaisesEditar" asp-route-id="@item.IdPais" class="btn btn-warning btn-sm fw-bold">
                                            Editar
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-3">Nenhum país cadastrado ainda.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>