@page
@model trabalho_kaneko.Pages.ClientesListarModel
@{
    ViewData["Title"] = "Gestão de Clientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestão de Clientes</h2>
        <a asp-page="/Clientes" class="btn btn-success fw-bold">+ Novo Cliente</a>
    </div>

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">@TempData["MensagemSucesso"]</div>
    }
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm">@TempData["MensagemErro"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white fw-bold">
            Clientes Cadastrados
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Cliente</th>
                            <th>CPF / CNPJ</th>
                            <th class="text-center" style="width: 150px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaClientes != null && Model.ListaClientes.Count > 0)
                        {
                            foreach (var item in Model.ListaClientes)
                            {
                                <tr>
                                    <td>@item.IdCliente</td>
                                    <td class="fw-bold">@item.Cliente</td>
                                    <td>@item.CpfCnpj</td>
                                    <td class="text-center align-middle">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-page="/ClientesEditar" asp-route-id="@item.IdCliente" class="btn btn-warning btn-sm fw-bold">
                                                Editar
                                            </a>

                                            <form method="post" asp-page-handler="Deletar" asp-route-id="@item.IdCliente"
                                                  onsubmit="return confirm('Tem certeza que deseja excluir este cliente?');"
                                                  class="m-0 p-0">
                                                <button type="submit" class="btn btn-danger btn-sm fw-bold">
                                                    Excluir
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">Nenhum cliente cadastrado ainda.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>