@page
@model trabalho_kaneko.Pages.FormasPagamentoListarModel
@{
    ViewData["Title"] = "Formas de Pagamento";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestão de Formas de Pagamento</h2>
        <a asp-page="/FormasPagamento" class="btn btn-success fw-bold">+ Nova Forma</a>
    </div>

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">@TempData["MensagemSucesso"]</div>
    }
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm">@TempData["MensagemErro"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white fw-bold">
            Formas Cadastradas
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 100px;">Código</th>
                            <th>Descrição da Forma</th>
                            <th style="width: 120px;" class="text-center">Status</th>
                            <th class="text-center" style="width: 160px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaFormas != null && Model.ListaFormas.Count > 0)
                        {
                            foreach (var item in Model.ListaFormas)
                            {
                                <tr>
                                    <td>@item.IdFormaPagamento</td>
                                    <td class="fw-bold">@item.FormaPagamento</td>
                                    <td class="text-center">
                                        @if (item.Ativo)
                                        {
                                            <span class="badge bg-success fw-bold">Ativo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger fw-bold">Inativo</span>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-page="/FormasPagamentoEditar" asp-route-id="@item.IdFormaPagamento" class="btn btn-warning btn-sm fw-bold">Editar</a>
                                            <form method="post" asp-page-handler="Deletar" asp-route-id="@item.IdFormaPagamento" onsubmit="return confirm('Deseja realmente excluir esta forma de pagamento?');" class="m-0 p-0">
                                                <button type="submit" class="btn btn-danger btn-sm fw-bold">Excluir</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">Nenhuma forma de pagamento cadastrada.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>