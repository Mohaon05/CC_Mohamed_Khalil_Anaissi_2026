@page
@model trabalho_kaneko.Pages.FornecedoresListarModel
@{
    ViewData["Title"] = "Gestão de Fornecedores";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestão de Fornecedores</h2>
        <a asp-page="/Fornecedores" class="btn btn-success fw-bold">+ Novo Fornecedor</a>
    </div>

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success fw-bold shadow-sm">@TempData["MensagemSucesso"]</div>
    }
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm">@TempData["MensagemErro"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white fw-bold">
            Fornecedores Cadastrados
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Fornecedor / Razão Social</th>
                            <th>Tipo</th>
                            <th>CPF / CNPJ</th>
                            <th>Cidade</th>
                            <th>Celular</th>
                            <th class="text-center" style="width: 140px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaFornecedores != null && Model.ListaFornecedores.Count > 0)
                        {
                            foreach (var item in Model.ListaFornecedores)
                            {
                                <tr>
                                    <td>@item.IdFornecedor</td>
                                    <td class="fw-bold">@item.Fornecedor</td>
                                    <td><span class="badge bg-info text-dark">@(item.TipoPessoa == "F" ? "Física" : "Jurídica")</span></td>
                                    <td>@item.CpfCnpj</td>
                                    <td>@item.NomeCidade</td>
                                    <td>@item.Celular</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <a asp-page="/FornecedoresEditar" asp-route-id="@item.IdFornecedor" class="btn btn-warning btn-sm fw-bold">Editar</a>
                                            <form method="post" asp-page-handler="Deletar" asp-route-id="@item.IdFornecedor" onsubmit="return confirm('Excluir este fornecedor?');" class="m-0 p-0">
                                                <button type="submit" class="btn btn-danger btn-sm fw-bold">Excluir</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">Nenhum fornecedor cadastrado.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>