@page
@model trabalho_kaneko.Pages.FormasPagamentoEditarModel
@{
    ViewData["Title"] = "Editar Forma de Pagamento";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/FormasPagamentoListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark fw-bold">
            <h4 class="mb-0">Editar Forma de Pagamento</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="FormaObj.IdFormaPagamento" />
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-3 align-items-center">
                    <div class="col-md-9">
                        <label class="form-label fw-bold">Descrição da Forma de Pagamento</label>
                        <input asp-for="FormaObj.FormaPagamento" class="form-control" required maxlength="50" />
                    </div>

                    <div class="col-md-3 pt-4">
                        <div class="form-check form-switch fs-5">
                            <input asp-for="FormaObj.Ativo" class="form-check-input" type="checkbox" role="switch">
                            <label class="form-check-label fw-bold" asp-for="FormaObj.Ativo">Forma Ativa</label>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>