@page
@model trabalho_kaneko.Pages.CidadesListarModel
@{
    ViewData["Title"] = "Cidades Cadastradas";
}

<div class="container mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Gestão de Cidades</h3>
        <a asp-page="/Cidades" class="btn btn-success fw-bold">+ Nova Cidade</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">Cidades Cadastradas</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Cidade</th>
                            <th>Estado</th>
                            <th>Data de Inclusão</th>
                            <th>Última Alteração</th>
                            <th class="text-center" style="width: 120px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaCidades != null && Model.ListaCidades.Count > 0)
                        {
                            foreach (var item in Model.ListaCidades)
                            {
                                <tr>
                                    <td>@item.IdCidade</td>
                                    <td class="fw-bold">@item.Cidade</td>
                                    <td>@item.NomeEstado</td>
                                    <td>@item.DataInclusao?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(item.DataAlteracao?.ToString("dd/MM/yyyy HH:mm"))</td>

                                    <td class="text-center">
                                        <a asp-page="/CidadesEditar" asp-route-id="@item.IdCidade" class="btn btn-warning btn-sm fw-bold">
                                            Editar
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-3">Nenhuma cidade cadastrada ainda.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>