@page
@model trabalho_kaneko.Pages.PaisesModel
@{
    ViewData["Title"] = "Novo País";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/PaisesListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm border-success">
        <div class="card-header bg-success text-white fw-bold">
            <h4 class="mb-0">+ Novo País</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label fw-bold campo-obrigatorio">País</label>
                        <input asp-for="PaisObj.Pais" class="form-control" required maxlength="60" placeholder="Ex: Brasil" style="text-transform: uppercase;" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold campo-obrigatorio">Sigla</label>
                        <input asp-for="PaisObj.Sigla" class="form-control" required maxlength="3" placeholder="BR" style="text-transform: uppercase;" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold campo-obrigatorio">DDI</label>
                        <input asp-for="PaisObj.Ddi" class="form-control" required maxlength="10" placeholder="+55" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold campo-obrigatorio">Moeda</label>
                        <input asp-for="PaisObj.Moeda" class="form-control" required maxlength="50" placeholder="Real (BRL)" style="text-transform: uppercase;" />
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4 fw-bold">Salvar País</button>
                </div>
            </form>
        </div>
    </div>
</div>