@page
@model trabalho_kaneko.Pages.CidadesModel
@{
    ViewData["Title"] = "Cadastro de Cidades";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-page="/CidadesListar" class="btn btn-secondary btn-sm">Voltar para a Lista</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">+ Nova Cidade</h4>
        </div>
        <div class="card-body">

            @if (TempData["MensagemSucesso"] != null)
            {
                <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-bold campo-obrigatorio">Cidade</label>
                        <input asp-for="Cidade.Cidade" class="form-control" placeholder="Ex: Curitiba" required maxlength="60" style="text-transform: uppercase;" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold campo-obrigatorio">Estado</label>

                        <div class="input-group">

                            <select asp-for="Cidade.IdEstado" class="form-select" id="selectEstado" required>
                                <option value="">-- Selecione um Estado --</option>
                                @if (Model.ListaEstadosDisponiveis != null)
                                {
                                    foreach (var estado in Model.ListaEstadosDisponiveis)
                                    {
                                        <option value="@estado.IdEstado">@estado.Estado - @estado.Uf (@estado.NomePais)</option>
                                    }
                                }
                            </select>

                            <button class="btn btn-outline-success fw-bold" type="button" data-bs-toggle="modal" data-bs-target="#modalNovoEstado">
                                + Novo
                            </button>

                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success px-4">Salvar Cidade</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNovoEstado" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-success">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold">📍 Cadastro Rápido de Estado</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold campo-obrigatorio">Estado</label>
                    <input type="text" id="modalEstadoNome" class="form-control" maxlength="50" placeholder="Ex: Paraná" style="text-transform: uppercase;" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold campo-obrigatorio">UF</label>
                    <input type="text" id="modalEstadoUf" class="form-control" maxlength="2" placeholder="Ex: PR" style="text-transform: uppercase;" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold campo-obrigatorio">País Correspondente</label>
                    <div class="d-flex gap-2">
                        <select id="modalEstadoPais" class="form-select" required>
                            <option value="">-- Selecione um País --</option>
                            @if (Model.ListaPaises != null)
                            {
                                foreach (var pais in Model.ListaPaises)
                                {
                                    <option value="@pais.IdPais">@pais.Pais</option>
                                }
                            }
                        </select>
                        <button class="btn btn-outline-success fw-bold text-nowrap" type="button" onclick="abrirModalPaisPorCima()">
                            + Novo
                        </button>
                    </div>
                </div>
                <div id="modalEstadoErro" class="text-danger fw-bold d-none mt-2">Erro ao salvar estado. Verifique os dados.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success fw-bold" onclick="salvarEstadoAjax()">Salvar Estado</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNovoPais" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-primary shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">🌍 Cadastro Rápido de País</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label fw-bold campo-obrigatorio">Nome do País</label>
                    <input type="text" id="modalPaisNome" class="form-control" maxlength="60" required />
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-6">
                        <label class="form-label fw-bold campo-obrigatorio">Sigla</label>
                        <input type="text" id="modalPaisSigla" class="form-control" maxlength="3" style="text-transform: uppercase;" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold campo-obrigatorio">DDI</label>
                        <input type="text" id="modalPaisDdi" class="form-control" maxlength="10" placeholder="+55" required />
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label fw-bold campo-obrigatorio">Moeda</label>
                    <input type="text" id="modalPaisMoeda" class="form-control" maxlength="50" placeholder="Ex: Real (BRL)" required />
                </div>
                <div id="modalPaisErro" class="text-danger fw-bold d-none mt-2">Erro ao salvar país. Verifique os dados.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary fw-bold" onclick="salvarPaisAjax()">Salvar País</button>
            </div>
        </div>
    </div>


@section Scripts {
    <script>
        // ==========================================
        // 1. FUNÇÃO: ABRIR MODAL PAÍS POR CIMA
        // ==========================================
        function abrirModalPaisPorCima() {
            const elModalPais = document.getElementById('modalNovoPais');
            elModalPais.style.zIndex = '1060';
            const modalPais = new bootstrap.Modal(elModalPais);
            modalPais.show();
        }

        // ==========================================
        // 2. FUNÇÃO: SALVAR PAÍS VIA AJAX
        // ==========================================
        function salvarPaisAjax() {
            const nome = document.getElementById('modalPaisNome').value;
            const sigla = document.getElementById('modalPaisSigla').value;
            const ddi = document.getElementById('modalPaisDdi').value;
            const moeda = document.getElementById('modalPaisMoeda').value;

            if(!nome || !sigla || !ddi || !moeda) {
                alert('Por favor, preencha todos os campos do país!');
                return;
            }

            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenElement) {
                alert('Erro: Token de segurança não encontrado.');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('paisNome', nome);
            formData.append('paisSigla', sigla);
            formData.append('paisDdi', ddi);
            formData.append('paisMoeda', moeda);

            fetch('?handler=CriarPaisRapido', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': tokenElement.value
                },
                body: formData.toString()
            })
            .then(response => {
                if (!response.ok) throw new Error("Erro de servidor");
                return response.json();
            })
            .then(data => {
                if (data.sucesso) {
                    // Atualiza o select do país dentro do modal de estado
                    const select = document.getElementById('modalEstadoPais');
                    const option = new Option(data.nome, data.id, true, true);
                    select.add(option);

                    // Fecha o modal de país
                    const modalPais = bootstrap.Modal.getInstance(document.getElementById('modalNovoPais'));
                    modalPais.hide();

                    // Limpa os campos
                    document.getElementById('modalPaisNome').value = '';
                    document.getElementById('modalPaisSigla').value = '';
                    document.getElementById('modalPaisDdi').value = '';
                    document.getElementById('modalPaisMoeda').value = '';
                    document.getElementById('modalPaisErro').classList.add('d-none');
                } else {
                    document.getElementById('modalPaisErro').classList.remove('d-none');
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                document.getElementById('modalPaisErro').classList.remove('d-none');
            });
        }

        // ==========================================
        // 3. FUNÇÃO: SALVAR ESTADO VIA AJAX
        // ==========================================
        function salvarEstadoAjax() {
            const nome = document.getElementById('modalEstadoNome').value;
            const uf = document.getElementById('modalEstadoUf').value;
            const idPais = document.getElementById('modalEstadoPais').value;

            if(!nome || !uf || !idPais) {
                alert('Por favor, preencha todos os campos do estado!');
                return;
            }

            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenElement) {
                alert('Erro: Token de segurança não encontrado.');
                return;
            }

            const formData = new URLSearchParams();
            formData.append('estadoNome', nome);
            formData.append('estadoUf', uf);
            formData.append('idPais', idPais);

            fetch('?handler=CriarEstadoRapido', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': tokenElement.value
                },
                body: formData.toString()
            })
            .then(response => {
                if (!response.ok) throw new Error("Erro de servidor.");
                return response.json();
            })
            .then(data => {
                if (data.sucesso) {
                    const select = document.getElementById('selectEstado');
                    const option = new Option(data.nome, data.id, true, true);
                    select.add(option);

                    const modal = bootstrap.Modal.getInstance(document.getElementById('modalNovoEstado'));
                    modal.hide();

                    document.getElementById('modalEstadoNome').value = '';
                    document.getElementById('modalEstadoUf').value = '';
                    document.getElementById('modalEstadoPais').value = '';
                    document.getElementById('modalEstadoErro').classList.add('d-none');
                } else {
                    document.getElementById('modalEstadoErro').classList.remove('d-none');
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                document.getElementById('modalEstadoErro').classList.remove('d-none');
            });
        }
    </script>
}